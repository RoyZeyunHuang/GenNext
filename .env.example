# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service Role Key — 服务端 admin 操作用（Dashboard → Settings → API → service_role key）
# SUPABASE_SERVICE_ROLE_KEY=
# 仅用于本地执行 SQL 迁移（Dashboard → Settings → Database → Connection string → URI）
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres

# Rednote Factory：可编辑「公共」内容工厂分类/文档的管理员邮箱（逗号分隔）
# RF_ADMIN_EMAILS=you@example.com

# AI
ANTHROPIC_API_KEY=
# Persona RAG：笔记向量嵌入（text-embedding-3-small），本地在 .env.local 配置
# OPENAI_API_KEY=

# 站点根 URL（发信附件从 public/ 读取；线上 Serverless 无本地文件时需此项以 HTTP 回退拉取 PDF）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (CRM) — 发信走 Resend；收件同步仍用 Gmail API
RESEND_API_KEY=re_xxxx
# 可选：发件人显示名（默认 INVO by USWOO）
# RESEND_FROM_NAME=INVO by USWOO
SENDER_EMAIL=invo.mrkt@nystudents.net
# 默认抄送/密送（可选，与界面填写合并；逗号分隔）
# DEFAULT_CC_EMAIL=
# DEFAULT_BCC_EMAIL=
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GMAIL_REFRESH_TOKEN=
